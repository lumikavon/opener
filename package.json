{
  "name": "opener",
  "version": "1.0.0",
  "description": "Desktop launcher application with offline support",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tailwind:build": "tailwindcss -i ./frontend/src/input.css -o ./frontend/dist/output.css --minify",
    "tailwind:watch": "tailwindcss -i ./frontend/src/input.css -o ./frontend/dist/output.css --watch",
    "test": "cargo test --manifest-path src-tauri/Cargo.toml"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0"
  }
}
